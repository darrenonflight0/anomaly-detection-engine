# Copy to `.env` and adjust. All variables are prefixed with SENTINEL_.

# --- message bus: "memory" (no broker, single process) or "kafka" ---
SENTINEL_BUS=memory
SENTINEL_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SENTINEL_KAFKA_TOPIC=metrics
SENTINEL_KAFKA_GROUP_ID=sentinel-detector

# --- embedded synthetic producer ---
SENTINEL_EMBEDDED_PRODUCER=true
SENTINEL_PRODUCER_RATE_HZ=12
SENTINEL_ANOMALY_PROBABILITY=0.015

# --- detection tuning ---
SENTINEL_WARMUP_SAMPLES=50
SENTINEL_EMA_SPAN=30
SENTINEL_ZSCORE_THRESHOLD=3.5
SENTINEL_IFOREST_THRESHOLD=0.68
SENTINEL_TDIGEST_COMPRESSION=200
SENTINEL_HLL_PRECISION=14
SENTINEL_HEAVY_HITTER_THRESHOLD=0.45
